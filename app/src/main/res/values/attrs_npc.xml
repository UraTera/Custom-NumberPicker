<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="NumberPickerCustom">

        <attr name="np_textArray" format="reference" />
        <!-- Текст -->
        <attr name="np_textColorNormal" format="color" />
        <attr name="np_textColorSelected" format="color" />
        <attr name="np_textSizeNormal" format="dimension" />
        <attr name="np_textSizeSelected" format="dimension" />

        <!-- Разделитель -->
        <attr name="np_dividerColor" format="color" />
        <attr name="np_dividerHeight" format="dimension" />
        <attr name="np_dividerOffset" format="dimension" />

        <attr name="np_min" format="integer" />
        <attr name="np_max" format="integer" />
        <attr name="np_showRows5" format="boolean" />

        <!-- Подсказка -->
        <attr name="np_textHint" format="string" />
        <attr name="np_textSizeHint" format="dimension" />
        <attr name="np_textColorHint" format="color" />

    </declare-styleable>


</resources>